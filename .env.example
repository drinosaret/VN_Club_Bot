# ========================================
# Hikaru Configuration — copy to .env and fill in
# ========================================

# REQUIRED: Discord bot token from the Developer Portal
# https://discord.com/developers/applications
TOKEN=your_discord_bot_token_here

# REQUIRED: Path to the SQLite database. Created automatically on first boot.
# Migrations run before any cog loads, so this will be initialized
# whether the file exists yet or not.
PATH_TO_DB=data/db.sqlite3

# ========================================
# Admin / Manager Configuration
# ========================================

# REQUIRED: Discord user IDs (comma-separated) authorized to operate the bot.
# AUTHORIZED_USERS are global: they edit the per-guild
# manager list via /manage_managers, and bypass guild-scope checks on
# any admin command. Keep this list small — usually just the host.
# To find your ID: Discord Settings → Advanced → Developer Mode, then
# right-click your name → Copy User ID.
AUTHORIZED_USERS=your_discord_user_id

# Per-guild VN managers (the users and roles that can use /manage_pool,
# /manage_voting, etc. in a specific server) are NOT configured here.
# Each guild's manager list lives in the DB and is edited via the
# `/manage_managers` slash command, which is itself restricted to
# AUTHORIZED_USERS. Pick the target server from the `guild_id`
# autocomplete dropdown when running `/manage_managers` — the server
# must always be selected explicitly.

# ========================================
# Optional features
# ========================================

# OPTIONAL: Channel ID where the bot posts startup and scheduled DB backups.
# Use 0 to disable backups entirely.
#
# Note: the backup is the *entire* SQLite file, which contains every
# guild's pool, votes, and reading logs the bot has touched. If the
# bot serves multiple unrelated communities, this channel sees all
# their data. Either point it at a private admin channel you control,
# or set it to 0.
DB_BACKUP_CHANNEL=0

# OPTIONAL: Path to the bot's log file. Defaults to ``hikaru_bot.log`` in the
# working directory. The Docker healthcheck reads the same env var and
# considers the bot healthy when this file has been touched in the last
# 10 minutes — change both if you move the log elsewhere.
LOG_FILE=hikaru_bot.log
